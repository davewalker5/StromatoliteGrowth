{
  "name": "3d-domed",
  "description": "Geometric, dome-shape, spatial-coupling, and rendering parameters for the 3-D circular domed stromatolite growth model.",
  "parameters": {
    "nx": {
      "value": 41,
      "units": "grid cells",
      "description": "Number of grid cells in the x direction of the rectangular computational grid that contains the circular domed footprint."
    },
    "ny": {
      "value": 41,
      "units": "grid cells",
      "description": "Number of grid cells in the y direction of the rectangular computational grid that contains the circular domed footprint."
    },
    "dx_mm": {
      "value": 1.0,
      "units": "mm",
      "description": "Horizontal spacing between neighbouring grid cells in both x and y directions."
    },
    "footprint_radius_mm": {
      "value": null,
      "units": "mm",
      "description": "Optional radius of the active circular stromatolite footprint; null uses the largest centred circle that fits inside the grid."
    },
    "dome_profile": {
      "value": "spherical_cap",
      "units": "category",
      "description": "Initial dome profile type. Supported values include spherical_cap, paraboloid, gaussian, and flat."
    },
    "initial_dome_height_mm": {
      "value": 8.0,
      "units": "mm",
      "description": "Maximum initial dome height added above the starting microbial mat thickness at the colony centre."
    },
    "initial_dome_radius_mm": {
      "value": null,
      "units": "mm",
      "description": "Optional radius used to shape the initial dome; null uses the active footprint radius."
    },
    "dome_curvature": {
      "value": 2.0,
      "units": "profile parameter",
      "description": "Curvature control for non-spherical dome profiles: exponent for paraboloid profiles and sigma fraction for Gaussian profiles."
    },
    "apply_normal_growth_projection": {
      "value": true,
      "units": "boolean",
      "description": "Whether to reduce vertical growth increment on steeper domed slopes using a surface-normal projection factor."
    },
    "lateral_smoothing_rate": {
      "value": 0.02,
      "units": "fraction/timestep",
      "description": "Fractional strength of nearest-neighbour surface smoothing applied within the active circular footprint each timestep."
    },
    "spatial_sediment_noise": {
      "value": 0.1,
      "units": "fraction",
      "description": "Relative random spatial variation applied to sediment supply across the active circular footprint."
    },
    "snapshot_count": {
      "value": 6,
      "units": "snapshots",
      "description": "Number of evenly spaced surface snapshots retained for visualisation."
    },
    "slice_y_index": {
      "value": null,
      "units": "grid index",
      "description": "Optional y-index used for the final cross-section slice; null selects the centre row."
    },
    "surface_render_z_padding_fraction": {
      "value": 0.08,
      "units": "fraction",
      "description": "Fractional vertical padding added around the rendered final surface height range."
    }
  }
}
