{
  "name": "biology",
  "description": "Shared biological, environmental, and sediment-forcing parameters for the stromatolite growth models.",
  "parameters": {
    "time_steps": {
      "value": 2200,
      "units": "steps",
      "description": "Number of explicit simulation steps to run."
    },
    "dt_days": {
      "value": 1.0,
      "units": "days",
      "description": "Length of one timestep."
    },
    "initial_mat_thickness_mm": {
      "value": 0.35,
      "units": "mm",
      "description": "Starting thickness of each newly exposed microbial mat."
    },
    "lamina_completion_thickness_mm": {
      "value": 1.25,
      "units": "mm",
      "description": "Legacy thickness threshold retained for comparison; active burial now depends on sediment deposition."
    },
    "surface_light": {
      "value": 1.0,
      "units": "relative",
      "description": "Relative incident light at the mat-water interface."
    },
    "light_amplitude": {
      "value": 0.35,
      "units": "fraction",
      "description": "Annual sinusoidal amplitude applied to mean surface light."
    },
    "light_peak_day": {
      "value": 172.0,
      "units": "day of year",
      "description": "Day of year when seasonal surface light reaches its maximum."
    },
    "min_surface_light": {
      "value": 0.15,
      "units": "relative",
      "description": "Minimum allowed surface light after seasonal forcing is applied."
    },
    "light_attenuation_per_mm": {
      "value": 0.08,
      "units": "1/mm",
      "description": "Legacy Beer-Lambert attenuation coefficient through the accumulating column; retained for comparison but not used for active surface growth."
    },
    "water_depth_mm": {
      "value": 100.0,
      "units": "mm",
      "description": "Water level above the initial stromatolite base."
    },
    "minimum_water_cover_mm": {
      "value": 5.0,
      "units": "mm",
      "description": "Minimum water cover retained above the active mat surface."
    },
    "water_light_attenuation_per_mm": {
      "value": 0.01,
      "units": "1/mm",
      "description": "Beer-Lambert light attenuation coefficient through the overlying water column."
    },
    "mean_temperature_c": {
      "value": 16.0,
      "units": "deg C",
      "description": "Mean annual temperature used for seasonal biological forcing."
    },
    "temperature_amplitude_c": {
      "value": 7.0,
      "units": "deg C",
      "description": "Annual sinusoidal amplitude applied to mean temperature."
    },
    "temperature_peak_day": {
      "value": 205.0,
      "units": "day of year",
      "description": "Day of year when seasonal temperature reaches its maximum."
    },
    "optimal_temperature_c": {
      "value": 25.0,
      "units": "deg C",
      "description": "Temperature at which the biological temperature multiplier is maximal."
    },
    "temperature_width_c": {
      "value": 12.0,
      "units": "deg C",
      "description": "Width of the bell-shaped biological temperature response."
    },
    "days_per_year": {
      "value": 365.25,
      "units": "days",
      "description": "Annual period used for seasonal forcing functions."
    },
    "max_growth_rate_per_day": {
      "value": 0.045,
      "units": "1/day",
      "description": "Maximum photosynthetic biomass growth rate."
    },
    "half_saturation_light": {
      "value": 0.22,
      "units": "relative",
      "description": "Light level where growth reaches half of its maximum."
    },
    "mortality_rate_per_day": {
      "value": 0.006,
      "units": "1/day",
      "description": "Biomass loss rate for active microbial layers."
    },
    "buried_mortality_rate_per_day": {
      "value": 0.03,
      "units": "1/day",
      "description": "Additional biomass loss rate after a layer has been buried."
    },
    "eps_production_rate_per_day": {
      "value": 0.035,
      "units": "1/day",
      "description": "Rate at which biomass produces EPS."
    },
    "eps_decay_rate_per_day": {
      "value": 0.008,
      "units": "1/day",
      "description": "EPS decay or compaction rate."
    },
    "sediment_input_mm_per_day": {
      "value": 0.006,
      "units": "mm/day",
      "description": "Potential sediment arriving from the water column."
    },
    "sediment_seasonal_amplitude": {
      "value": 0.45,
      "units": "fraction",
      "description": "Annual sinusoidal amplitude applied to baseline sediment supply."
    },
    "sediment_peak_day": {
      "value": 25.0,
      "units": "day of year",
      "description": "Day of year when slow seasonal sediment supply reaches its maximum."
    },
    "min_sediment_multiplier": {
      "value": 0.25,
      "units": "fraction",
      "description": "Minimum allowed seasonal sediment multiplier."
    },
    "storm_probability_per_day": {
      "value": 0.012,
      "units": "1/day",
      "description": "Probability of a rare storm sediment pulse on any simulated day."
    },
    "storm_sediment_mm_per_day": {
      "value": 0.05,
      "units": "mm/day",
      "description": "Mean additional sediment supply during a storm pulse."
    },
    "storm_noise_fraction": {
      "value": 0.45,
      "units": "fraction",
      "description": "Relative random variation in storm sediment pulse size."
    },
    "trapping_efficiency": {
      "value": 0.75,
      "units": "fraction",
      "description": "Maximum fraction of arriving sediment retained by EPS."
    },
    "eps_half_saturation": {
      "value": 0.18,
      "units": "relative",
      "description": "EPS level where sediment trapping reaches half of maximum."
    },
    "biomass_to_thickness": {
      "value": 0.16,
      "units": "mm/relative",
      "description": "Thickness contribution from newly produced biomass."
    },
    "eps_to_thickness": {
      "value": 0.05,
      "units": "mm/relative",
      "description": "Thickness contribution from newly produced EPS."
    },
    "sediment_to_thickness": {
      "value": 1.0,
      "units": "mm/mm",
      "description": "Thickness contribution from trapped sediment."
    },
    "burial_sediment_threshold_mm": {
      "value": 0.7,
      "units": "mm",
      "description": "Cumulative trapped sediment cover required to bury the active mat and start a new lamina."
    },
    "rapid_burial_sediment_threshold_mm": {
      "value": 0.035,
      "units": "mm/timestep",
      "description": "Single-timestep trapped sediment pulse large enough to trigger rapid burial."
    },
    "new_layer_biomass_seed": {
      "value": 0.08,
      "units": "relative",
      "description": "Biomass carried into a new surface mat after burial."
    },
    "new_layer_eps_seed": {
      "value": 0.04,
      "units": "relative",
      "description": "EPS carried into a new surface mat after burial."
    },
    "random_seed": {
      "value": 7,
      "units": "integer",
      "description": "Seed used for reproducible small sediment-supply variation."
    },
    "sediment_noise_fraction": {
      "value": 0.25,
      "units": "fraction",
      "description": "Relative random variation in sediment input at each step."
    }
  }
}
