{
  "name": "2d-rectangle",
  "description": "Geometric and spatial-coupling parameters for the 2-D rectangular cross-section stromatolite growth model.",
  "parameters": {
    "nx": {
      "value": 101,
      "units": "grid cells",
      "description": "Number of horizontal cells in the rectangular cross-section transect."
    },
    "dx_mm": {
      "value": 1.0,
      "units": "mm",
      "description": "Horizontal spacing between neighbouring transect cells."
    },
    "initial_surface_noise_mm": {
      "value": 0.2,
      "units": "mm",
      "description": "Amplitude of small random height perturbations used to seed initial surface relief."
    },
    "lateral_smoothing_rate": {
      "value": 0.02,
      "units": "fraction/timestep",
      "description": "Fractional strength of nearest-neighbour lateral smoothing applied to the active surface each timestep."
    },
    "spatial_sediment_noise": {
      "value": 0.1,
      "units": "fraction",
      "description": "Relative random spatial variation applied to sediment supply across the transect."
    },
    "snapshot_count": {
      "value": 8,
      "units": "snapshots",
      "description": "Number of evenly spaced surface snapshots retained for visualisation."
    }
  }
}
